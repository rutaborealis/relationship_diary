# ── Local development only (.env.local) ──────────────────────────────────
# Copy to .env.local and fill in values. Never commit real secrets.

# DynamoDB Local endpoint — enables local dev mode (docker compose up)
DYNAMO_ENDPOINT=http://localhost:8000

# AWS config (used only for DynamoDB Local; in Lambda these come from the IAM role)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Table names (must match setup-local-dynamo.ts)
STAGE=dev
TABLE_NAME=DiaryMain-dev
PUSH_TABLE_NAME=DiaryPush-dev

# JWT secret for local dev (in production stored in SSM /diary/jwt-secret)
JWT_SECRET=change-me-local-dev-secret

# VAPID keys for Web Push (generate with: npm run generate-vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=dev@example.com

# SES sender (in local dev emails are printed to console)
SES_FROM_ADDRESS=no-reply@yourdomain.com

# Content encryption (lib/crypto.ts).
# Local "fake KMS": auto-on when DYNAMO_ENDPOINT is set; force with KMS_LOCAL=1.
# LOCAL_ENC_KEY is REQUIRED in local mode (no default) — wraps the data key
# locally (any string, hashed to 32 bytes). The crypto lib throws on startup if
# it is missing. Keep it stable across runs/migration or previously-encrypted
# local rows won't decrypt. In production this is replaced by a real KMS CMK
# (KMS_KEY_ID); STAGE=prod with KMS_LOCAL or no KMS_KEY_ID fails fast.
KMS_LOCAL=1
LOCAL_ENC_KEY=change-me-local-dev-enc-key

# App domain (used in invite email links)
APP_DOMAIN=http://localhost:3000

# Server port
PORT=3000

# ── Production (set in AWS SSM Parameter Store) ───────────────────────────
# aws ssm put-parameter --name /diary/jwt-secret        --value <secret> --type SecureString
# aws ssm put-parameter --name /diary/vapid-public-key  --value <key>    --type SecureString
# aws ssm put-parameter --name /diary/vapid-private-key --value <key>    --type SecureString
# aws ssm put-parameter --name /diary/vapid-email       --value <email>  --type String